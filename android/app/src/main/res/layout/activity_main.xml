<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.mssdvd.platestracker.ui.OverlayView
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- High-visibility warning while burst/ring is suspended (thermal SEVERE+) — the small HUD
         token was easy to miss while driving. -->
    <TextView
        android:id="@+id/thermalBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:padding="10dp"
        android:background="#CCB00020"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Freshly promoted plate, flashed large for a few seconds (glanceable while driving). -->
    <LinearLayout
        android:id="@+id/flashGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="40dp"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:background="#B0000000"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/bigPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#24FF0C"
            android:textSize="56sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- country, estimated registration year, corrected marker -->
        <TextView
            android:id="@+id/bigPlateSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9BE895"
            android:textSize="18sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Rolling log of the latest recorded sightings. -->
    <TextView
        android:id="@+id/recentLog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:padding="6dp"
        android:background="#80000000"
        android:textColor="#E6E9EF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <!-- Shown until the server URL + token are configured. -->
    <TextView
        android:id="@+id/bannerConfig"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="#CC5A4500"
        android:textColor="#FFD23F"
        android:textSize="14sp"
        android:text="@string/banner_not_configured"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/hud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginBottom="8dp"
            android:padding="4dp"
            android:background="#80000000"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/dim"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/history" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/settings" />

            <!-- One-tap start: the only control needed while mounted (no interaction at speed). -->
            <Button
                android:id="@+id/btnToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="120dp"
                android:text="@string/start" />
        </LinearLayout>
    </LinearLayout>

    <!-- Blackout mode: capture keeps running with the preview surface detached; only a dim
         minimal HUD stays visible (OLED: black pixels are off). Tap anywhere to restore. -->
    <FrameLayout
        android:id="@+id/blackout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/blackoutHud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="#4A5560"
            android:textSize="16sp"
            android:fontFamily="monospace" />
    </FrameLayout>
</FrameLayout>
